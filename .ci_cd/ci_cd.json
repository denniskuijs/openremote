{
	"push": {
		"master": {
			"distribute": {
				"docker": "develop-core",
				"npm": "$version-core-snapshot"
			}
		}
	},
  "workflow_dispatch": {
    "deploy": {
      "snapshot": {
        "managerTag": "develop",
        "environment": "staging"
      },
      "release": {
        "managerTag": "latest",
        "environment": "demo"
      }
    }
  },
	"release": {
		"distribute": {
			"docker": "latest-core,$version-core",
			"npm": "$version-core"
		}
	}
}
