{
	"push": {
		"master": {
			"distribute": {
				"docker": "develop-core",
				"npm": "$version-core-snapshot"
			}
		}
	},
  "workflow_dispatch": {
    "deploy": {
      "managerTag": "develop",
      "environment": "staging"
    }
  },
	"release": {
		"distribute": {
			"docker": "latest-core,$version-core",
			"npm": "$version-core"
		},
		"deploy": {
			"managerTag": "latest",
			"environment": "demo"
		}
	}
}
