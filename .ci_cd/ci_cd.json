{
	"push": {
		"master": {
			"distribute": {
				"docker": "develop-core",
				"npm": "$version-core-snapshot"
			},
			"deploy": {
				"managerTag": "develop-core",
				"environment": "staging"
			}
		}
	},
	"release": {
		"distribute": {
			"docker": "latest-core,$version-core",
			"npm": "$version-core"
		},
		"deploy": {
			"managerTag": "latest-core",
			"environment": "demo"
		}
	}
}
